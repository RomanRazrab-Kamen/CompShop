<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:CompShop.ViewModels"
             xmlns:models="using:CompShop.Models"
             x:DataType="vm:CatalogViewModel"
             mc:Ignorable="d" 
             d:DesignWidth="1000" 
             d:DesignHeight="600"
             x:Class="CompShop.Views.CatalogView">

    <Grid ColumnDefinitions="250, *">
        <Border Grid.Column="0" Padding="15">
            <StackPanel Spacing="15">
                <TextBlock Text="Фильтры" FontSize="18" FontWeight="Bold"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="Поиск по названию" FontSize="12" />
                    <TextBox Text="{Binding SearchText, Mode=TwoWay}" PlaceholderText="Введите модель..."/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Категория"/>
                    <ComboBox ItemsSource="{Binding Categories}" 
                              SelectedItem="{Binding SelectedCategory}" 
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:Category">
                                <TextBlock Text="{Binding CategoryName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Цена до (руб.)" FontSize="12"/>
                    <NumericUpDown Value="{Binding MaxPrice}" Minimum="0" Increment="1000"/>
                </StackPanel>

                <Button Content="Сбросить фильтры" 
                        Command="{Binding ResetFiltersCommand}" 
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto, *" Margin="20">
            <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,15">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="Найдено компонентов:"/>
                    <TextBlock Text="{Binding ItemsCount}" FontWeight="Bold"/>
                </StackPanel>
                
                <ComboBox Grid.Column="1" Width="180" PlaceholderText="Сортировка"
                          SelectedIndex="{Binding SelectedSortIndex, Mode=TwoWay}">
                    <ComboBoxItem Content="Сначала дешевые"/>
                    <ComboBoxItem Content="Сначала дорогие"/>
                </ComboBox>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <ListBox ItemsSource="{Binding Components}"
                         SelectedItem="{Binding SelectedComponent, Mode=TwoWay}"
                         Background="Transparent">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Component">
                            <Border Width="220" Height="210" Padding="12"
                                    CornerRadius="8" BorderThickness="1"
                                    BorderBrush="{DynamicResource SystemControlBorderRasterBrush}"
                                    Background="{DynamicResource SystemControlBackgroundChromeLowBrush}">
                                <Grid RowDefinitions="*, Auto">
                                    <StackPanel Grid.Row="0" Spacing="4">
                                        <TextBlock Text="{Binding ComponentName}" 
                                                   FontWeight="Bold" FontSize="14" 
                                                   TextWrapping="Wrap" MaxLines="2"/>
                                        <TextBlock Text="{Binding Category.CategoryName}" FontSize="12"
                                                   Foreground="{DynamicResource SystemControlBackgroundBaseMediumBrush}"/>
                                    </StackPanel>

                                    <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Price, StringFormat='{}{0:N0} ₽'}" 
                                                       FontSize="16" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding StockStatus, FallbackValue='В наличии'}" FontSize="11"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="1" Content="+" 
                                                Command="{Binding $parent[ListBox].DataContext.AddToRepairCommand}"
                                                CommandParameter="{Binding}"
                                                 IsVisible="{Binding $parent[ListBox].DataContext.CanAddToRepair}"
                                                FontSize="16" FontWeight="Bold" CornerRadius="20" 
                                                Width="35" Height="35"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
