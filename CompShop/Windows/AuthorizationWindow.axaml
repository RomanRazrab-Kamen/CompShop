<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CompShop.ViewModels"
        xmlns:local="using:CompShop"
        x:Class="CompShop.Windows.AuthorizationWindow"
        x:DataType="vm:AuthorizationViewModel"
        Title="Авторизация — CompShop" 
        Width="400" Height="500"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

   <Grid Background="{DynamicResource SystemRegionBrush}">
        
        <!-- Карточка входа: рамка и фон подстраиваются сами -->
        <Border Background="{DynamicResource SystemControlTransientBackgroundBrush}" 
                BorderBrush="{DynamicResource SystemControlBorderRasterBrush}"
                BorderThickness="1"
                CornerRadius="8" 
                Padding="30" 
                Margin="40"
                VerticalAlignment="Center" 
                HorizontalAlignment="Stretch">
            
            <StackPanel Spacing="20">
                <!-- Логотип и Заголовок -->
                <StackPanel HorizontalAlignment="Center" Spacing="8" Margin="0,0,0,10">
                    <TextBlock Text="💻" FontSize="40" HorizontalAlignment="Center"/>
                    <TextBlock Text="Вход в систему" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Компьютерный магазин" FontSize="12" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Поле Логина -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Логин (Email)" FontSize="12" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}"/>
                    <TextBox Text="{Binding LoginText, Mode=TwoWay}" 
                             PlaceholderText="Введите ваш логин..."
                             Padding="10,8"/>
                </StackPanel>

                <!-- Поле Пароля -->
                <StackPanel Spacing="5">
                    <TextBlock Text="Пароль" FontSize="12" Foreground="{DynamicResource SystemControlPageTextBaseMediumBrush}"/>
                    <TextBox Text="{Binding PasswordText, Mode=TwoWay}" 
                             PasswordChar="●" 
                             PlaceholderText="Введите ваш password..."
                             Padding="10,8"/>
                </StackPanel>

                <!-- Сообщение об ошибке (берет системный красный цвет для ошибок) -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}" 
                           FontSize="12" 
                           HorizontalAlignment="Center"
                           TextWrapping="Wrap"
                           IsVisible="{Binding IsErrorVisible}"/>

                <!-- Кнопка Войти (Класс accent покрасит её в системный цвет Accent) -->
                <Button Content="Войти" 
                        Command="{Binding LoginCommand}"
                        Classes="accent"
                        HorizontalAlignment="Stretch" 
                        HorizontalContentAlignment="Center"
                        Padding="0,12" 
                        FontSize="14" 
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
